    "brace-expansion": "^2.0.1",
    "@tootallnate/once": "^2.0.0",
    "ws": "^7.5.10",
    "cross-spawn": "^7.0.6",
    "micromatch": "^4.0.8",
    "path-to-regexp": "^0.1.12",
