    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.3.1",
    "react-router-dom": "^5.3.4"
  },
  "resolutions": {
    "follow-redirects": "^1.15.6",
    "braces": "^3.0.3",
